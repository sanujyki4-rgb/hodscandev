# =============================================================================
# L1 — Ethereum (untuk indexing pesan L1->L2 retryable ticket)
# 2 endpoint header-free: ZAN utama, PublicNode cadangan (failover otomatis).
# =============================================================================
L1_RPC_URLS=https://api.zan.top/node/v1/eth/mainnet/9ddb07c56de64c5aafc86ed5d013c404,https://ethereum-rpc.publicnode.com


# =============================================================================
# Robinhood Chain RPC — capability-aware multi-provider (SATU-SATUNYA sumber)
#   ZAN       = bulk      → block / tx / receipts / logs massal
#   Uniblock  = primary   → query harian + trace (butuh X-API-KEY)
#   QuickNode = fallback  → cadangan darurat (JANGAN log range besar, maks 5 blok)
# Tiap provider boleh punya banyak URL (dipisah koma) → failover otomatis.
# =============================================================================

# --- ZAN (bulk) — 2 endpoint ---
#   URL #1: key 2f572f83... (utama) | URL #2: key f0160c02... (cadangan)
ZAN_RPC_URLS=https://api.zan.top/node/v1/robinhood/mainnet/2f572f8319004705b683221368b31aaf,https://api.zan.top/node/v1/robinhood/mainnet/f0160c0271084d74b3f297c3494caeff

# --- Uniblock (primary + trace) — URL sama (chainId=4663), 2 API key = 2x kuota ---
#   UNIBLOCK_API_KEYS sejajar urutannya dgn URL: key #1 → URL #1, key #2 → URL #2
UNIBLOCK_RPC_URLS=https://api.uniblock.dev/uni/v1/json-rpc?chainId=4663,https://api.uniblock.dev/uni/v1/json-rpc?chainId=4663
UNIBLOCK_API_KEYS=d2z-g0kLz31qctZKcNfUHs2X4eds7WqsKYrmY4ViDZ4,lW8R7E1AY1s0XbPubsBgyEC014611smO_HSZwVnetOk

# --- QuickNode (fallback) — 2 endpoint ---
#   URL #1: little-icy-yard... (utama) | URL #2: black-lingering... (cadangan)
QUICKNODE_RPC_URLS=https://little-icy-yard.robinhood-mainnet.quiknode.pro/1aa979eaf2eff5713b2a0712ad459ba296b9598b/,https://black-lingering-silence.robinhood-mainnet.quiknode.pro/2309a98f9094adc9f95ba7ed782dc29abd590122/

# Batas log-range (default aman, uncomment kalau mau ubah)
# ZAN_MAX_LOG_RANGE_BLOCKS=10000
# QUICKNODE_MAX_LOG_RANGE_BLOCKS=5

RH_CHAIN_ID=4663

# =============================================================================
# Gapless backfill
# =============================================================================
BACKFILL_DIRECTION=reverse
BACKFILL_DELAY_MS=100

# =============================================================================
# Database / Redis / API / Indexer
# =============================================================================
DATABASE_URL=postgresql://hoodscan:hoodscan@localhost:5432/hoodscan
REDIS_URL=redis://localhost:6379
API_PORT=4000
INDEXER_POLL_INTERVAL_MS=500
