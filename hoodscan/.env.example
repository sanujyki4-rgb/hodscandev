# =============================================================================
# L2 — Robinhood Chain RPC (multi-endpoint)
# =============================================================================
# You can set SEVERAL endpoints at once. The indexer/API round-robin across
# them for load (e.g. multiple Alchemy keys) and fail over if one is down.
#
# Any mix works: public RH RPC + Alchemy apps + your own node + Ankr, etc.

# Preferred: comma-separated full URLs (any provider)
# RH_RPC_URLS=https://rpc.mainnet.chain.robinhood.com,https://YOUR-L2.g.alchemy.com/v2/KEY1,https://YOUR-L2.g.alchemy.com/v2/KEY2

# Backward compatible single URL (still works; merged into the list)
RH_RPC_URL_MAINNET=https://rpc.mainnet.chain.robinhood.com
RH_RPC_URL_TESTNET=https://rpc.testnet.chain.robinhood.com
RH_CHAIN_ID=4663

# Optional Alchemy convenience for L2 — expands keys into full URLs.
# Requires ALCHEMY_L2_NETWORK (Alchemy subdomain for Robinhood / your app).
# ALCHEMY_L2_API_KEYS=key1,key2,key3
# ALCHEMY_L2_NETWORK=robinhood-mainnet

# =============================================================================
# L1 — Ethereum mainnet RPC (multi-endpoint)
# Only needed for the L1->L2 message watcher job.
# =============================================================================
# Prefer multiple Alchemy keys (or Alchemy + Infura/Ankr) to avoid rate limits
# on eth_getLogs.

# Preferred: comma-separated full URLs
# L1_RPC_URLS=https://eth-mainnet.g.alchemy.com/v2/KEY1,https://eth-mainnet.g.alchemy.com/v2/KEY2,https://rpc.ankr.com/eth

# Backward compatible single URL (still works; merged into the list)
L1_RPC_URL_MAINNET=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY_HERE

# Optional Alchemy convenience for L1 — just paste API keys (no full URL).
# Defaults network to eth-mainnet.
# ALCHEMY_L1_API_KEYS=key1,key2,key3
# ALCHEMY_L1_NETWORK=eth-mainnet

# =============================================================================
# Database / Redis / apps
# =============================================================================
DATABASE_URL=postgresql://hoodscan:hoodscan@localhost:5432/hoodscan
REDIS_URL=redis://localhost:6379
API_PORT=4000
INDEXER_POLL_INTERVAL_MS=500
