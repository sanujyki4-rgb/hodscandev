# Robinhood Chain RPC
RH_RPC_URL_MAINNET=https://rpc.mainnet.chain.robinhood.com
RH_RPC_URL_TESTNET=https://rpc.testnet.chain.robinhood.com
RH_CHAIN_ID=4663

# Ethereum L1 RPC — only needed for the L1->L2 message watcher job
# (indexes retryable tickets from the Bridge contract on Ethereum
# mainnet). Use a real provider (Alchemy/Infura/etc) — there is no
# rate-limit-friendly public default for L1 like there is for the
# Robinhood Chain RPC above. Leave empty to disable the watcher job.
L1_RPC_URL_MAINNET=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY_HERE

# Database
DATABASE_URL=postgresql://hoodscan:hoodscan@localhost:5432/hoodscan

# Redis
REDIS_URL=redis://localhost:6379

# API
API_PORT=4000

# Indexer
INDEXER_POLL_INTERVAL_MS=500
